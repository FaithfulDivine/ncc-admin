# Supabase — from dashboard: Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Shopify store URL
VITE_SHOPIFY_STORE_URL=https://your-store.myshopify.com

# Shopify OAuth credentials (for token refresh)
SHOPIFY_CLIENT_ID=your-client-id
SHOPIFY_CLIENT_SECRET=your-client-secret

# Shopify Admin API token (auto-filled by refresh button, leave empty)
SHOPIFY_ACCESS_TOKEN=

# ── CJ Dropshipping (optional; ưu tiên dùng Supabase system_settings) ──
# Khi set env → override giá trị trong DB cho phiên serverless đó.
CJ_API_EMAIL=
CJ_API_PASSWORD=
CJ_WEBHOOK_SECRET=
